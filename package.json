{
  "name": "lti-tool",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "docs:build": "typedoc",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt --write .",
    "type-check": "tsc --noEmit",
    "smoke-test:dist": "node scripts/smoke-test-dist.mjs",
    "test": "vitest --exclude=\"**/*.integration.test.ts\"",
    "test:coverage": "vitest run --coverage --exclude=\"**/*.integration.test.ts\"",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typedoc": "^0.28.20",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "fast-xml-parser": ">=5.8.0"
  }
}
